# Konfigurace admin panelu (/admin).
# Lokálně: zkopíruj tento soubor jako .env.local a doplň hodnoty.
# Produkce: nastav stejné proměnné na Vercelu (Settings → Environment Variables).

# Heslo pro přihlášení do admin panelu.
ADMIN_PASSWORD=

# GitHub fine-grained personal access token s právem "Contents: Read and write"
# pouze pro repozitář vencoslav1357/sdhporin.
# Vytvoření: github.com → Settings → Developer settings → Fine-grained tokens.
GITHUB_TOKEN=

# Volitelné (výchozí hodnoty):
# GITHUB_REPO=vencoslav1357/sdhporin
# GITHUB_BRANCH=main
